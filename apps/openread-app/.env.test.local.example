# apps/openread-app/.env.test.local.example
#
# Copy to .env.test.local and fill in the values. The real file is
# gitignored — do NOT check it in.
#
# The Playwright config auto-loads .env.test.local when running e2e
# specs (see apps/openread-app/playwright.config.ts top-of-file env
# loader). The Next.js dev server spawned by `pnpm dev-web` loads
# .env.web separately.

# Shared test account — same user across all 5 platform projects.
# Use a dedicated low-privilege Supabase account, not a real user.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Supabase project — the same values Vercel uses. test-users.ts derives
# the `sb-<projectRef>-auth-token` localStorage key from the URL.
NEXT_PUBLIC_SUPABASE_URL=https://qxnavppqosndhfgitdsi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
