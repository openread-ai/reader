{
  "extends": "@openread/tsconfig/nextjs.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext", "WebWorker"],
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/components/ui/*": ["./src/components/primitives/*"],
      "@pdfjs/*": ["./public/vendor/pdfjs/*"],
      "@simplecc/*": ["./public/vendor/simplecc/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "raw-loader.d.ts",
    "simplecc-wasm.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "src/stories", "e2e", "playwright.config.ts"]
}
